# Streamlit Cloud > App Settings > Secrets 에 아래 내용을 붙여넣으세요
# (이 파일은 예시용 — 실제 secrets.toml은 .gitignore로 보호됩니다)

# 대시보드 접근 비밀번호
password = "여기에_비밀번호_입력"

# DART OpenAPI 키 (https://opendart.fss.or.kr)
DART_API_KEY = "여기에_DART_API_KEY_입력"

# Telegram 알림 (선택)
TELEGRAM_BOT_TOKEN = "여기에_BOT_TOKEN_입력"
TELEGRAM_CHAT_ID   = "여기에_CHAT_ID_입력"
